generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  profiles      Profile[]
  myList        MyList[]
  watchProgress WatchProgress[]
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  avatar    String
  kids      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MyList {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mediaId   String
  mediaType String

  title      String
  posterPath String?
  overview   String?

  createdAt DateTime @default(now())

  @@unique([userId, mediaId, mediaType])
}

model WatchProgress {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mediaId   String
  mediaType String

  title      String
  posterPath String?
  overview   String?

  progress Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mediaId, mediaType])
}

model Movie {
  id String @id @default(cuid())

  title String

  description String?

  poster String

  backdrop String?

  videoUrl String?

  trailerUrl String?

  category String?

  year Int?

  tmdbId String? @unique

  sourceType String @default("tmdb")

  available Boolean @default(false)

  views Int @default(0)

  featured Boolean @default(false)

  published Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
model SiteSettings {

  id String @id @default(cuid())

  siteName String @default("NIPFLIX")

  description String?

  logo String?

  heroTitle String?

  heroDescription String?

  maintenance Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

}