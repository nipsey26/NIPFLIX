generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  myList        MyList[]
  watchProgress WatchProgress[]
}

model MyList {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mediaId   String
  mediaType String

  title      String
  posterPath String?
  overview   String?

  createdAt DateTime @default(now())

  @@unique([userId, mediaId, mediaType])
}

model WatchProgress {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mediaId   String
  mediaType String

  title      String
  posterPath String?
  overview   String?

  progress Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mediaId, mediaType])
}
